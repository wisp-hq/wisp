{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wisp",
  "version": "0.5.0",
  "identifier": "com.wisp-hq.wisp",
  "build": {
    "beforeBuildCommand": "cd ../client && bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Wisp",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Wisp desktop shell",
    "longDescription": "Wisp shell — embeds the Wisp client PWA and connects to a user-configured Wisp instance."
  }
}
